enum ReturnType {
  REFUND
  REPLACEMENT
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKED_UP
  COMPLETED
}

enum ReturnReason {
  DAMAGED_PRODUCT
  DEFECTIVE_PRODUCT
  WRONG_ITEM
  SIZE_ISSUE
  QUALITY_ISSUE
  NOT_NEEDED
  OTHER
}

model Return {
  id                 String @id @default(uuid())

  orderId            String
  order              Order @relation(fields: [orderId], references: [id])

  userId             String
  user               User @relation(fields: [userId], references: [id])

  type               ReturnType

  status             ReturnStatus @default(REQUESTED)

  reason             ReturnReason

  description        String?

  adminRemark        String?

  rejectionReason    String?

  pickupTrackingId   String?

  replacementOrderId String? @unique
  replacementOrder   Order? @relation("ReplacementOrder", fields: [replacementOrderId], references: [id])

  approvedAt         DateTime?

  rejectedAt         DateTime?

  pickedUpAt         DateTime?

  completedAt        DateTime?

  metadata           Json?

  createdAt          DateTime @default(now())

  updatedAt          DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([userId, status])
  @@index([status, createdAt])

  @@map("returns")
}

