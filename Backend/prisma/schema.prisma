  shippingFee Decimal @db.Decimal(10, 2)
  freeShippingThreshold Decimal @db.Decimal(10, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("shipping_configurations")
}