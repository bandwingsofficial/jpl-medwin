enum BannerType {
  HOME_BANNER
  CATEGORY_BANNER
  SUB_CATEGORY_BANNER
  PROMOTIONAL_BANNER
  PRODUCT_BANNER
}

enum BannerStatus {
  ACTIVE
  INACTIVE
}

model Banner {
  id          String         @id @default(uuid())

  name        String
  type        BannerType

  status      BannerStatus   @default(ACTIVE)

  images      BannerImage[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  deletedAt   DateTime?

  @@index([type])
  @@index([status])
  @@index([deletedAt])

  @@map("banners")
}

model BannerImage {
  id          String       @id @default(uuid())

  bannerId    String
  banner      Banner       @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  imageUrl    String

  productId   String?
  product     Product?     @relation(fields: [productId], references: [id])

  sortOrder   Int          @default(0)

  status      BannerStatus @default(ACTIVE)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  deletedAt   DateTime?

  @@index([bannerId])
  @@index([productId])
  @@index([bannerId, sortOrder])
  @@index([status])
  @@index([deletedAt])

  @@map("banner_images")
}
