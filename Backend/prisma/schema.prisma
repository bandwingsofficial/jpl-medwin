// =======================
// GENERATOR & DATASOURCE
// =======================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// ENUMS
// =======================

enum Platform {
  WEB
  ANDROID
  IOS
}

enum AuthMethod {
  PHONE
  EMAIL
  GOOGLE
}

enum OtpPurpose {
  LOGIN
  SIGNUP
  PASSWORD_RESET
  TRANSACTION
}

enum OtpStatus {
  SENT
  VERIFIED
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

// 🔥 FIXED (no string type anymore)
enum SessionType {
  USER
  ADMIN
  API
}

// =======================
// USER (CORE IDENTITY)
// =======================

model User {
  id             String   @id @default(uuid())

  name           String?
  profilePic     String?

  isActive       Boolean  @default(true)
  role           UserRole @default(USER)

  // 🔐 Token invalidation
  tokenVersion   Int      @default(0)

  deletedAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  sessions       Session[]
  identities     AuthIdentity[]
  otpLogs        OtpLog[]
  savedAddresses SavedAddress[]
  carts Cart[]
  orders Order[]
  wishlists Wishlist[]

  coinWallet CoinWallet?
rewardTier UserRewardTier?
coinTransactions CoinTransaction[]
coinRedemptions CoinRedemption[]
returns Return[]

  profile Profile?

  @@index([createdAt])
  @@index([deletedAt])
  @@index([role])
}

// =======================
// AUTH IDENTITY (LOGIN METHODS)
// =======================

model AuthIdentity {
  id          String     @id @default(uuid())

  userId      String
  type        AuthMethod
  value       String

  isVerified  Boolean    @default(false)

  // 🔐 ADMIN LOGIN SUPPORT
  passwordHash   String?   // bcrypt/argon2
  totpSecret     String?   // should be encrypted
  isTotpEnabled  Boolean   @default(false)

  // Soft delete
  deletedAt   DateTime?

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // 🔥 FIXED (soft delete safe)
  @@unique([type, value, deletedAt])

  @@index([userId])
  @@index([value])
  @@index([type, value])
  @@index([deletedAt])
}

// =======================
// SESSION (DEVICE LOGIN)
// =======================

model Session {
  id                 String   @id @default(uuid())

  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId           String
  platform           Platform?

  // 🔥 FIXED (enum instead of string)
  type               SessionType?

  // 🔐 Store HASH, NOT raw token
  refreshTokenHash   String   @unique

  expiresAt          DateTime

  isRevoked          Boolean  @default(false)
  revokedAt          DateTime?
  replacedByToken    String?

  deviceName         String?
  ipAddress          String?
  userAgent          String?

  lastUsedAt         DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([isRevoked])
  @@index([lastUsedAt])

  // ❌ REMOVED (handled in app layer)
  // @@unique([userId, deviceId])
}

// =======================
// OTP LOGS (AUDIT)
// =======================

model OtpLog {
  id          String     @id @default(cuid())

  userId      String?
  identifier  String

  purpose     OtpPurpose
  status      OtpStatus

  // 🔥 FIXED (expiry tracking)
  expiresAt   DateTime

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime   @default(now())

  user        User?      @relation(fields: [userId], references: [id])

  @@index([identifier])
  @@index([userId])
  @@index([purpose])
  @@index([status])
  @@index([createdAt])
}

// =======================
// PROFILE
// =======================

model Profile {
  id          String   @id @default(cuid())

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String?
  email       String?  @unique
  phoneNumber String?  @unique

  avatarUrl   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deletedAt   DateTime?
}

enum AddressType {
  HOME
  WORK
  OTHER
}

model SavedAddress {
  id            String        @id @default(cuid())

  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 👤 Contact Details
  fullName      String?
  phoneNumber   String

  // 📍 Address Info
  type          AddressType

  alias         String?

  addressLine1  String
  addressLine2  String?

  landmark      String?

  city          String
  state         String
  country       String
  postalCode    String

  // 🌍 Location
  latitude      Decimal?      @db.Decimal(10, 7)
  longitude     Decimal?      @db.Decimal(10, 7)

  // ⭐ Default Address
  isDefault     Boolean       @default(false)

  // 🗑 Soft Delete
  deletedAt     DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // 📦 Order relations
  shippingOrders Order[] @relation("OrderShippingAddress")
  billingOrders  Order[] @relation("OrderBillingAddress")

  @@index([userId])
  @@index([type])
  @@index([isDefault])
  @@index([deletedAt])

  @@index([userId, type])
  @@index([userId, isDefault])

  // 📞 Useful for quick lookup/search
  @@index([phoneNumber])
}


enum CategoryStatus {
  ACTIVE
  INACTIVE
}

// =======================
// CATEGORY
// =======================
model Category {
  id              String   @id @default(cuid())

  name            String
  slug            String

  imageUrl        String?

  description     String?
  metaDescription String?

  status          CategoryStatus @default(ACTIVE)

  deletedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subCategories   SubCategory[]
  miniCategories  MiniCategory[]
  products Product[] @relation("CategoryProducts")

  @@unique([slug, deletedAt])

  @@index([slug, deletedAt])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}

// =======================
// SUB CATEGORY
// =======================
model SubCategory {
  id              String   @id @default(cuid())

  name            String
  slug            String

  imageUrl        String?

  description     String?
  metaDescription String?

  status          CategoryStatus @default(ACTIVE)

  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  deletedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  miniCategories  MiniCategory[]
  products Product[] @relation("SubCategoryProducts")

  @@unique([categoryId, slug, deletedAt])

  @@index([categoryId])
  @@index([categoryId, slug, deletedAt])
  @@index([categoryId, name])
  @@index([status])
  @@index([deletedAt])
}

// =======================
// MINI CATEGORY
// =======================
model MiniCategory {
  id              String   @id @default(cuid())

  name            String
  slug            String

  imageUrl        String?

  description     String?
  metaDescription String?

  status          CategoryStatus @default(ACTIVE)

  categoryId      String
  subCategoryId   String

  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory     SubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)

  deletedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  products Product[] @relation("MiniCategoryProducts")

  @@unique([subCategoryId, slug, deletedAt])

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([subCategoryId, slug, deletedAt])
  @@index([status])
  @@index([deletedAt])
}

enum BrandStatus{
  ACTIVE
  INACTIVE
}

model Brand {
  id              String   @id @default(cuid())

  name            String
  slug            String   @unique

  imageUrl        String?   // ✅ added

  description     String?
  metaDescription String?

  status          BrandStatus @default(ACTIVE)

  // Soft delete
  deletedAt       DateTime?
  products Product[] @relation("BrandProducts")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 🔒 Unique slug (soft delete safe)
  @@unique([slug, deletedAt])

  // ⚡ Indexing
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}


// ================= ENUMS =================

enum ProductType {
  SIMPLE
  VARIABLE
}

enum ImageOwnerType {
  PRODUCT
  VARIANT
}

enum ImageType {
  MAIN
  GALLERY
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

// ================= PRODUCT =================

model Product {
  id               String   @id @default(cuid())

  // 🔗 Relations
  categoryId       String
  subCategoryId    String
  miniCategoryId   String
  brandId          String

  category     Category     @relation("CategoryProducts", fields: [categoryId], references: [id])
  subCategory  SubCategory  @relation("SubCategoryProducts", fields: [subCategoryId], references: [id])
  miniCategory MiniCategory @relation("MiniCategoryProducts", fields: [miniCategoryId], references: [id])
  brand        Brand        @relation("BrandProducts", fields: [brandId], references: [id])

  // 🧾 Basic Info
  name             String
  slug             String

  type             ProductType  @default(VARIABLE)

  // ⭐ Default Variant
  defaultVariantId String?

  shortDescription String?
  longDescription  String?

  // 📦 Content
  features         String[]
  displayNotes     String[]
  tags             String[]

  specifications   Json?
  packing          Json?
  directionOfUse   Json?
  additionalInfo   Json?
  faq              Json?

  // 💰 Pricing Range
  minPrice         Float?
  maxPrice         Float?
  currency         String  @default("INR")

  // ⭐ Reviews
  averageRating    Float  @default(0)
  reviewCount      Int    @default(0)

  // ⚙️ Extra
  isWeighted       Boolean @default(false)
  warrantyMonths   Int?

  status           ProductStatus @default(ACTIVE)

  searchText       String?

  deletedAt        DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // 🔗 Relations
  variants         Variant[]
  images           ProductImage[]
  cartItems CartItem[]
  wishlists Wishlist[]
  collectionProducts CollectionProduct[]
    bannerImages  BannerImage[]

  // ================= CONSTRAINTS =================
  @@unique([slug, deletedAt])

  // ================= INDEXES =================
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([miniCategoryId])
  @@index([brandId])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])

  // 🔥 IMPORTANT PERFORMANCE INDEX
  @@index([categoryId, status, deletedAt])
}

// ================= VARIANT =================

model Variant {
  id              String   @id @default(cuid())

  // 🔗 Relation
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 🆔 Identity
  sku             String
  name            String
  slug            String

  // 💰 Pricing
  purchasePrice   Float
  sellingPrice    Float
  mrp             Float

  // 📦 Inventory
  quantity        Int @default(0)

  // ⚙️ Attributes
  attributes      Json?

  // ⭐ Reviews
  averageRating   Float @default(0)
  reviewCount     Int   @default(0)
  isWeighted      Boolean @default(false)
warrantyMonths  Int?

  status          ProductStatus @default(ACTIVE)
  deletedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 🔗 Relations
  images          ProductImage[]
  cartItems CartItem[]

  // ================= UNIQUE =================
  @@unique([productId, sku, deletedAt])
  @@unique([productId, slug, deletedAt])

  // ================= INDEXES =================
  @@index([productId])
  @@index([sellingPrice])
  @@index([status])
  @@index([deletedAt])
  @@index([slug])

  // 🔥 IMPORTANT PERFORMANCE INDEX
  @@index([productId, deletedAt])
}

// ================= PRODUCT IMAGE =================

model ProductImage {
  id         String   @id @default(cuid())

  url        String
  alt        String?
  sortOrder  Int      @default(0)

  type       ImageType
  ownerType  ImageOwnerType

  deletedAt  DateTime?

  productId  String?
  variantId  String?

  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    Variant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ================= INDEXES =================
  @@index([productId, deletedAt])
  @@index([variantId, deletedAt])
  @@index([ownerType])
  @@index([type])
  @@index([sortOrder])
  @@index([deletedAt])
}


// =======================
// ENUMS
// =======================

enum CartStatus {
  ACTIVE
  LOCKED
  CONVERTED
  ABANDONED
  EXPIRED
  MERGED
}

// =======================
// CART
// =======================

model Cart {
  id                String      @id @default(uuid())

  userId            String?
  guestId           String?

  status            CartStatus  @default(ACTIVE)

  couponId String?
  couponCode String?
  couponDiscount Decimal? @db.Decimal(12,2)

  lockedAt          DateTime?

  mergedIntoCartId  String?

  expiresAt         DateTime?

  deletedAt         DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // RELATIONS

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon            Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  mergedIntoCart    Cart? @relation("MergedCart", fields: [mergedIntoCartId], references: [id], onDelete: SetNull)
  mergedCarts       Cart[] @relation("MergedCart")
  items             CartItem[]
  checkoutSessions CheckoutSession[]
  orders Order[]

  // INDEXES

  @@index([userId])
  @@index([guestId])
  @@index([status])
  @@index([deletedAt])
  @@index([expiresAt])
  @@index([createdAt])
  @@unique([guestId, status])
}

// =======================
// CART ITEM
// =======================

model CartItem {
  id                String   @id @default(uuid())
  cartId            String
  productId         String
  variantId         String

  quantity          Int

  // SNAPSHOTS

  productName       String
  variantName       String?
  sku               String?
  imageUrl          String?

  // PRICE SNAPSHOT

  price             Decimal  @db.Decimal(12, 2)
  mrp               Decimal? @db.Decimal(12, 2)

  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // RELATIONS

  cart              Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant           Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // INDEXES

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@index([deletedAt])
  @@index([createdAt])
  @@unique([cartId, variantId])
}

model Wishlist {
  id        String   @id @default(uuid())

  // =======================
  // 👤 USER
  // =======================

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // =======================
  // 📦 PRODUCT
  // =======================

  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // =======================
  // 🕒 TIMESTAMPS
  // =======================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =======================
  // ♻️ SOFT DELETE
  // =======================

  deletedAt DateTime?

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlists")
}

enum CheckoutSessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  FAILED
}

model CheckoutSession {
  id                 String @id @default(uuid())
  cartId             String
  userId             String?
  guestId            String?
  status             CheckoutSessionStatus   @default(ACTIVE)
  couponCode         String?
  subtotal           Decimal @db.Decimal(12,2)
  couponDiscount   Float @default(0)
  shippingCharge     Decimal @db.Decimal(12,2)
  tax                Decimal @db.Decimal(12,2)
  grandTotal         Decimal @db.Decimal(12,2)
  totalSavings       Decimal @db.Decimal(12,2)

  rewardCoinsUsed Int? @default(0)
  rewardDiscount Float? @default(0)
  expiresAt          DateTime
  completedAt        DateTime?
  failedAt           DateTime?
  metadata           Json?
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // RELATIONS

  cart               Cart @relation(fields: [cartId], references: [id], onDelete: Restrict)
  items              CheckoutSessionItem[]
  orders Order[]

  @@index([cartId])
  @@index([userId])
  @@index([guestId])
  @@index([status])
}

model CheckoutSessionItem {
  id                 String @id @default(uuid())
  checkoutSessionId  String
  productId          String
  variantId          String
  quantity           Int

  // SNAPSHOTS

  productName        String
  variantName        String?
  sku                String?
  imageUrl           String?

  // PRICE SNAPSHOT

  price              Decimal @db.Decimal(12,2)
  mrp                Decimal? @db.Decimal(12,2)
  totalPrice         Decimal @db.Decimal(12,2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // RELATIONS

  checkoutSession   CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)

  @@index([checkoutSessionId])
}

// =======================
// ENUMS
// =======================

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  RETURNED
}

enum PaymentStatus {
  PENDING
  CREATED
  AUTHORIZED
  CAPTURED
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

// =======================
// ORDER
// =======================

model Order {
  id String @id @default(uuid())

  // =======================
  // 🔢 ORDER NUMBER
  // =======================

  orderNumber String @unique

  // =======================
  // 🔗 SOURCE
  // =======================

  cartId String?
  checkoutSessionId String?
  userId String?

  // =======================
  // 📦 STATUS
  // =======================

  status OrderStatus @default(PENDING_PAYMENT)
  paymentStatus PaymentStatus @default(PENDING)

  // =======================
  // 🎟 COUPON
  // =======================

  couponCode String?

  // =======================
  // 💰 TOTAL SNAPSHOT
  // =======================

  subtotal Decimal @db.Decimal(12, 2)
  couponDiscount Decimal @db.Decimal(12, 2) @default(0)
  shippingCharge Decimal @db.Decimal(12, 2) @default(0)
  tax Decimal @db.Decimal(12, 2) @default(0)
  grandTotal Decimal @db.Decimal(12, 2)
  totalSavings Decimal @db.Decimal(12, 2) @default(0)

  // =======================
  // 📍 ADDRESS REFERENCES
  // =======================

  shippingAddressId String?
  billingAddressId String?
  isBillingSameAsShipping Boolean @default(true)

  shippingAddress SavedAddress? @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress SavedAddress? @relation("OrderBillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)

  shippingAddressSnapshot Json?
  billingAddressSnapshot Json?

  // =======================
  // 💳 PAYMENT SNAPSHOT
  // =======================

  payments Payment[]

  // =======================
  // 🚚 SHIPPING
  // =======================

  trackingId String?
courierName String?

  shippedAt DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?
  rewardRefunded Boolean @default(false)
  refundedAt DateTime?

  // =======================
  // 📝 NOTES
  // =======================

  customerNote String?
  adminNote String?

  // =======================
  // 📦 METADATA
  // =======================

  metadata Json?

  // =======================
  // 🕒 TIMESTAMPS
  // =======================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =======================
  // ♻️ DELETE
  // =======================

  deletedAt DateTime?

  // =======================
  // RELATIONS
  // =======================

  items OrderItem[]
  returns Return[]
  replacementFor Return? @relation("ReplacementOrder")

 checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
 cart Cart? @relation(fields: [cartId], references: [id], onDelete: SetNull)
 user User? @relation(fields: [userId], references: [id])
coinTransactions CoinTransaction[]
 coinRedemption CoinRedemption?

earnedCoins Int @default(0)

redeemedCoins Int @default(0)

redeemedAmount Decimal @db.Decimal(12,2) @default(0)

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([shippingAddressId])
  @@index([billingAddressId])
  @@map("orders")
}

// =======================
// ORDER ITEM
// =======================

model OrderItem {
  id String @id @default(uuid())

  // =======================
  // 🔗 RELATIONS
  // =======================

  orderId String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // =======================
  // 📦 PRODUCT SNAPSHOT
  // =======================

  productId String
  variantId String

  // =======================
  // 📸 SNAPSHOT
  // =======================

  productName String
  variantName String?
  sku String?
  imageUrl String?

  // =======================
  // 📦 QUANTITY
  // =======================

  quantity Int

  // =======================
  // 💰 PRICE SNAPSHOT
  // =======================

  price Decimal @db.Decimal(12, 2)
  mrp Decimal? @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  totalMrp Decimal? @db.Decimal(12, 2)
  totalSavings Decimal? @db.Decimal(12, 2)

  // =======================
  // 🕒 TIMESTAMPS
  // =======================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =======================
  // ♻️ DELETE
  // =======================

  deletedAt DateTime?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

// =======================
// PAYMENT PROVIDER
// =======================

enum PaymentProvider {
  RAZORPAY
  STRIPE
  COD
  MANUAL
}

// =======================
// PAYMENT STATUS------ inside oder enum
// =======================

// =======================
// PAYMENT METHOD
// =======================

enum PaymentMethod {
  CARD
  UPI
  NETBANKING
  WALLET
  EMI
  COD
}

model Payment {
  id String @id @default(uuid())

  // =======================
  // 🔗 RELATIONS
  // =======================

  orderId String

  order Order @relation(fields: [orderId],references: [id], onDelete: Cascade)

  // =======================
  // 💳 PROVIDER
  // =======================

  provider PaymentProvider
  method PaymentMethod?

  // =======================
  // 📦 STATUS
  // =======================

  status PaymentStatus @default(PENDING)

  // =======================
  // 💰 MONEY
  // =======================

  amount Decimal @db.Decimal(12, 2)

  currency String @default("INR")

  refundedAmount Decimal @db.Decimal(12, 2) @default(0)

  // =======================
  // 🆔 PROVIDER IDS
  // =======================

  providerOrderId String?
  providerPaymentId String?
  providerRefundId String?
  providerSignature String?

  // =======================
  // 📄 WEBHOOKS
  // =======================

  webhookEvent String?
  webhookPayload Json?

  // =======================
  // ❌ FAILURE
  // =======================

  failureCode String?
  failureReason String?

  // =======================
  // 🔁 RETRY
  // =======================

  retryCount Int @default(0)

  // =======================
  // 🧾 METADATA
  // =======================

  metadata Json?

  coinTransactions CoinTransaction[]

  // =======================
  // 🕒 TIMESTAMPS
  // =======================

  authorizedAt DateTime?
  capturedAt DateTime?
  failedAt DateTime?
  refundedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =======================
  // ♻️ DELETE
  // =======================

  deletedAt DateTime?

  // =======================
  // INDEXES
  // =======================

  @@index([orderId])
  @@index([status])
  @@index([provider])
  @@index([providerPaymentId])
  @@index([createdAt])
  @@map("payments")
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

model Coupon {
  id String @id @default(uuid())

  // =======================
  // BASIC
  // =======================

  code String @unique

  title String?
  description String?

  // =======================
  // DISCOUNT
  // =======================

  discountType CouponDiscountType

  discountValue Decimal @db.Decimal(12,2)

  maximumDiscountAmount Decimal? @db.Decimal(12,2)

  // =======================
  // CONDITIONS
  // =======================

  minimumOrderAmount Decimal? @db.Decimal(12,2)

  usageLimit Int?

  usedCount Int @default(0)

  perUserLimit Int?

  // =======================
  // STATUS
  // =======================

  status CouponStatus @default(ACTIVE)

  isPublic Boolean @default(true)

  // =======================
  // VALIDITY
  // =======================

  startsAt DateTime?

  expiresAt DateTime?

  // =======================
  // METADATA
  // =======================

  metadata Json?

  // =======================
  // TIMESTAMPS
  // =======================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deletedAt DateTime?
  carts Cart[]
  redemptions CouponRedemption[]

  // =======================
  // INDEXES
  // =======================

  @@index([code])
  @@index([status])
  @@index([expiresAt])
  @@index([deletedAt])
}

model CouponRedemption {
  id String @id @default(uuid())

  // =======================
  // RELATIONS
  // =======================

  couponId String

  coupon Coupon @relation(fields: [couponId], references: [id])

  // =======================
  // TRACKING
  // =======================

  userId String

  orderId String

  discountAmount Decimal @db.Decimal(12,2)

  // =======================
  // TIMESTAMPS
  // =======================

  createdAt DateTime @default(now())

  // =======================
  // INDEXES
  // =======================

@@index([couponId])

@@index([userId])

@@index([orderId])

@@index([couponId, userId])

@@unique([couponId, userId, orderId])
}


enum CoinTransactionType {
  EARNED
  BONUS
  REDEEMED
  REDEEM_REVERSED
  REFUNDED
  ORDER_REWARD_REVERSED
  EXPIRED
  ADMIN_CREDIT
  ADMIN_DEBIT
  ADJUSTED
}

enum CoinTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum CoinRedemptionStatus {
  PENDING
  APPLIED
  REVERSED
  FAILED
}

enum RewardTierStatus {
  ACTIVE
  INACTIVE
}

enum RewardSourceType {
  ORDER
  REDEMPTION
  REFERRAL
  CAMPAIGN
  ADMIN
  REFUND
  SYSTEM
}

model RewardConfig {
  id String @id @default(uuid())
  earnRateAmount Decimal @db.Decimal(12,2)
  earnRateCoins Int
  coinValue Decimal @db.Decimal(12,2) @default(1)
  maxRedemptionPercentage Decimal @db.Decimal(5,2)
  minimumOrderAmount Decimal? @db.Decimal(12,2)
  expiryMonths Int @default(12)
  rewardOnDelivered Boolean @default(true)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RewardTier {
  id String @id @default(uuid())
  name String
  description String?
  status RewardTierStatus @default(ACTIVE)
  coinMultiplier Decimal @db.Decimal(5,2)
  minimumLifetimeSpend Decimal @db.Decimal(12,2)
  badgeImage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users UserRewardTier[]
}

model UserRewardTier {
  id String @id @default(uuid())
  userId String @unique
  rewardTierId String
  totalLifetimeSpend Decimal @db.Decimal(12,2) @default(0)
  startedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardTier RewardTier @relation(fields: [rewardTierId], references: [id])

  @@index([rewardTierId])
}

model CoinWallet {
  id String @id @default(uuid())
  userId String @unique
  balance Int @default(0)
  lifetimeEarned Int @default(0)
  lifetimeRedeemed Int @default(0)
  lifetimeExpired Int @default(0)
  lifetimeRefunded Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CoinTransaction[]
  redemptions CoinRedemption[]

  @@index([balance])
}

model CoinTransaction {
  id String @id @default(uuid())
  walletId String
  userId String
  orderId String?
  paymentId String?
  redemptionId String?
  type CoinTransactionType
  status CoinTransactionStatus @default(SUCCESS)
  coins Int
  balanceBefore Int
  balanceAfter Int
  description String?
  reason String?
  sourceType RewardSourceType?
  idempotencyKey String? @unique
  expiresAt DateTime?
  expiredAt DateTime?
  remainingCoins Int @default(0)
  createdByAdminId String?
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet CoinWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  redemption CoinRedemption? @relation(fields: [redemptionId], references: [id], onDelete: SetNull)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([userId])
  @@index([orderId])
  @@index([paymentId])
  @@index([redemptionId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([sourceType])
  @@index([userId, createdAt])
  @@index([walletId, createdAt])
}

model CoinRedemption {
  id String @id @default(uuid())
  orderId String @unique
  userId String
  walletId String
  status CoinRedemptionStatus @default(PENDING)
  redeemedCoins Int
  redeemedAmount Decimal @db.Decimal(12,2)
  reversedAt DateTime?
  reversalReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  wallet CoinWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CoinTransaction[]

  @@index([userId])
  @@index([walletId])
  @@index([status])
}

model RewardCampaign {
  id String @id @default(uuid())
  title String
  description String?
  bonusMultiplier Decimal @db.Decimal(5,2)
  startsAt DateTime
  endsAt DateTime
  isActive Boolean @default(true)
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startsAt])
  @@index([endsAt])
  @@index([isActive])
}


  // =======================
  // COLLECTIONS
  // =======================

enum CollectionStatus {
  ACTIVE
  INACTIVE
}
model Collection {
  id              String @id @default(cuid())

  // =======================
  // BASIC
  // =======================

  name            String
  slug            String
  imageUrl        String?
  description     String?
  metaDescription String?
  status          CollectionStatus @default(ACTIVE)

  // =======================
  // RELATIONS
  // =======================

  products        CollectionProduct[]

  // =======================
  // TIMESTAMPS
  // =======================

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // =======================
  // INDEXES
  // =======================

  @@unique([slug, deletedAt])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("collections")
}

model CollectionProduct {
  id String @id @default(cuid())

  // =======================
  // RELATIONS
  // =======================

  collectionId String
  productId String

  collection Collection @relation(fields: [collectionId],references: [id],onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id],onDelete: Cascade)

  // =======================
  // DISPLAY ORDER
  // =======================

  sortOrder Int @default(0)

  // =======================
  // TIMESTAMPS
  // =======================

  createdAt DateTime @default(now())

  // =======================
  // CONSTRAINTS
  // =======================

  @@unique([collectionId, productId])

  @@index([collectionId])

  @@index([productId])

  @@map("collection_products")
}


