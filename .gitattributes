# Auto detect text files
* text=auto

# Source Files
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.css text
*.scss text
*.html text
*.md text

# Shell Scripts
*.sh text eol=lf

# Windows Scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# YAML
*.yml text
*.yaml text

# Binary Files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary